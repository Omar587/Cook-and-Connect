@{
    ViewData["Title"] = "Artisan Kitchen — RecipeFinder";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">

<style>
    /* ─── BASE RESET ─── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body {
        font-family: 'DM Sans', sans-serif;
        background-color: #fdfaf6;
        color: #1a1a1a;
        line-height: 1.6;
        overflow-x: hidden;
    }

    .container {
        max-width: 1520px;
        margin: 0 auto;
        padding: 0 2.5rem;
    }

    /* ─── HERO SECTION ─── */
    .hero {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        min-height: 95vh;
        align-items: center;
        gap: 5rem;
        padding-top: 2rem;
    }

    .hero-content {
        z-index: 10;
    }

    .eyebrow {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.35em;
        color: #e85d26;
        font-weight: 700;
        margin-bottom: 2.5rem;
        display: flex;
        align-items: center;
        gap: 1.2rem;
    }

    .eyebrow::after {
        content: '';
        height: 1px;
        width: 50px;
        background: #e85d26;
    }

    .hero-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(3.5rem, 6.5vw, 7rem);
        line-height: 0.9;
        font-weight: 300;
        margin-bottom: 2.5rem;
        letter-spacing: -0.04em;
    }

    .hero-title em {
        font-style: italic;
        color: #e85d26;
        font-weight: 400;
    }

    .hero-sub {
        font-size: 1.15rem;
        color: #6e675f;
        max-width: 500px;
        margin-bottom: 3.5rem;
        font-weight: 300;
    }

    /* Hero Bento Visuals */
    .hero-visuals {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-template-rows: repeat(12, 1fr);
        height: 85vh;
        position: relative;
    }

    .visual-box {
        overflow: hidden;
        border-radius: 2px;
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.12);
        transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    }

    .visual-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.5s ease;
    }

    .visual-main {
        grid-column: 1 / 11;
        grid-row: 1 / 11;
        z-index: 2;
    }

    .visual-overlap {
        grid-column: 6 / 13;
        grid-row: 7 / 13;
        z-index: 3;
        border: 15px solid #fdfaf6;
    }

    .visual-box:hover img { transform: scale(1.1); }

    .floating-badge {
        position: absolute;
        top: 10%;
        right: -5%;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        padding: 2.5rem;
        border-radius: 50%;
        width: 140px;
        height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        border: 1px solid rgba(0,0,0,0.05);
        z-index: 4;
        animation: rotateBadge 25s linear infinite;
    }

    @@keyframes rotateBadge {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* ─── BUTTONS ─── */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 1.2rem;
        padding: 1.3rem 3rem;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    }

    .btn-dark {
        background: #1a1a1a;
        color: #ffffff;
    }

    .btn-dark:hover {
        background: #e85d26;
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(232, 93, 38, 0.2);
    }

    /* ─── MARQUEE ─── */
    .marquee {
        background: #1a1a1a;
        color: #ffffff;
        padding: 1.8rem 0;
        overflow: hidden;
        white-space: nowrap;
        display: flex;
        border-radius: 4px;
        margin: 4rem 0;
    }

    .marquee-content {
        display: flex;
        animation: scroll 40s linear infinite;
    }

    .marquee-text {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.4em;
        margin-right: 5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        opacity: 0.6;
    }

    .marquee-text::after {
        content: '✦';
        color: #e85d26;
    }

    @@keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    /* ─── RECIPE CARDS ─── */
    .section-pad { padding: 10rem 0; }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 5rem;
    }

    .recipe-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 3rem;
    }

    .recipe-card {
        text-decoration: none;
        color: inherit;
        display: block;
        transition: all 0.5s ease;
    }

    .recipe-img-container {
        aspect-ratio: 4/5;
        overflow: hidden;
        background: #f0e9dc;
        margin-bottom: 2rem;
        position: relative;
    }

    .recipe-img-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .recipe-card:hover .recipe-img-container img {
        transform: scale(1.08);
    }

    .recipe-badge {
        position: absolute;
        top: 1.5rem;
        left: 1.5rem;
        background: rgba(255, 255, 255, 0.95);
        padding: 0.5rem 1rem;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .recipe-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.2rem;
        line-height: 1.1;
        font-weight: 500;
        margin-bottom: 0.8rem;
    }

    .recipe-meta {
        font-size: 0.85rem;
        color: #6e675f;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        display: flex;
        gap: 1rem;
    }

    /* ─── RESPONSIVE ─── */
    @@media (max-width: 1024px) {
        .hero { grid-template-columns: 1fr; text-align: center; }
        .hero-content { display: flex; flex-direction: column; align-items: center; }
        .hero-sub { margin-left: auto; margin-right: auto; }
        .hero-visuals { height: 60vh; }
    }
</style>

<main class="container">
    <section class="hero">
        <div class="hero-content">
            <div class="eyebrow">The Global Culinary Journal</div>
            <h1 class="hero-title">
                Cook with <em>Purpose</em>.<br>
                Live with Flavor.
            </h1>
            <p class="hero-sub">
                A curated sanctuary for the home chef. Discover artisanal recipes from across the globe, refine your technique, and archive your kitchen triumphs.
            </p>
            <div class="hero-actions">
                <a href="/Recipe" class="btn btn-dark">Explore the Archive</a>
            </div>
            
            <div style="margin-top: 6rem; display: flex; gap: 5rem;">
                <div>
                    <span style="display:block; font-family:'Cormorant Garamond'; font-size: 3rem; color: #1a1a1a;">200+</span>
                    <span style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.2em; color:#6e675f; font-weight:700;">Artisan Recipes</span>
                </div>
                <div>
                    <span style="display:block; font-family:'Cormorant Garamond'; font-size: 3rem; color: #1a1a1a;">34</span>
                    <span style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.2em; color:#6e675f; font-weight:700;">Global Cuisines</span>
                </div>
            </div>
        </div>

        <div class="hero-visuals">
            <div class="floating-badge">Member <br> Favorite</div>
            <div class="visual-box visual-main">
                <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1200&q=80" alt="Plated Salmon">
            </div>
            <div class="visual-box visual-overlap">
                <img src="https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=800&q=80" alt="Fresh Grilling">
            </div>
        </div>
    </section>
</main>

<div class="marquee">
    <div class="marquee-content">
        @for(int i=0; i<3; i++) {
            <span class="marquee-text">Mediterranean Kitchen</span>
            <span class="marquee-text">Japanese Umami</span>
            <span class="marquee-text">Rustic Italian</span>
            <span class="marquee-text">Oaxacan Spice</span>
            <span class="marquee-text">Nordic Minimalism</span>
        }
    </div>
</div>

<section class="container section-pad">
    <header class="section-header">
        <div>
            <div class="eyebrow">Seasonal Highlights</div>
            <h2 style="font-family:'Cormorant Garamond'; font-size: 4rem; font-weight: 300; letter-spacing:-0.03em;">This Week's <em>Selection</em></h2>
        </div>
        <a href="/Recipe" style="color: #1a1a1a; text-transform: uppercase; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.25em; text-decoration: none; border-bottom: 2px solid #e85d26; padding-bottom: 5px;">View Full Archive</a>
    </header>

    <div class="recipe-grid">
        @{
            var featured = ViewBag.FeaturedRecipes as IEnumerable<RecipeFinder.Models.Recipe>;
            if (featured != null && featured.Any())
            {
                foreach (var recipe in featured.Take(4))
                {
                    <a href="@Url.Action("Details","Recipe",new{id=recipe.Id})" class="recipe-card">
                        <div class="recipe-img-container">
                            <span class="recipe-badge">@recipe.Cuisine</span>
                            <img src="@recipe.ImageUrl" alt="@recipe.Name" loading="lazy">
                        </div>
                        <h3 class="recipe-title">@recipe.Name</h3>
                        <div class="recipe-meta">
                            <span>@recipe.TotalTime() Mins</span>
                            <span style="color: #e8ddd0;">|</span>
                            <span>@recipe.Difficulty</span>
                        </div>
                    </a>
                }
            }
        }
    </div>
</section>

<section style="background: #1a1a1a; color: #ffffff; padding: 8rem 0; border-radius: 4px;" class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 4rem; padding: 0 4rem;">
        <div style="text-align: center;">
            <span style="font-family: 'Cormorant Garamond'; font-size: 4rem; color: #e85d26; display: block; margin-bottom: 1rem;">01</span>
            <h4 style="text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.9rem; margin-bottom: 1rem;">Discover</h4>
            <p style="font-size: 0.9rem; opacity: 0.5; font-weight: 300;">Browse our vast library of vetted, world-class recipes.</p>
        </div>
        <div style="text-align: center;">
            <span style="font-family: 'Cormorant Garamond'; font-size: 4rem; color: #e85d26; display: block; margin-bottom: 1rem;">02</span>
            <h4 style="text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.9rem; margin-bottom: 1rem;">Customize</h4>
            <p style="font-size: 0.9rem; opacity: 0.5; font-weight: 300;">Adjust servings, take notes, and save favorites to your library.</p>
        </div>
        <div style="text-align: center;">
            <span style="font-family: 'Cormorant Garamond'; font-size: 4rem; color: #e85d26; display: block; margin-bottom: 1rem;">03</span>
            <h4 style="text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.9rem; margin-bottom: 1rem;">Share</h4>
            <p style="font-size: 0.9rem; opacity: 0.5; font-weight: 300;">Join the forum to debate techniques and show off results.</p>
        </div>
    </div>
</section>
