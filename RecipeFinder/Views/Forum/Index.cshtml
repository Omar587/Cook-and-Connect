@model RecipeFinder.ViewModels.Forum.ForumIndexViewModel
@{
    ViewData["Title"] = "Community Forum";

    string Initials(string name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name[0].ToString().ToUpper();

    string AvatarColor(string name)
    {
        var colors = new[] { "#c0513d","#2d6a4f","#b5550a","#1d4ed8","#6d28d9","#be185d","#0e7490" };
        return colors[Math.Abs((name ?? "?").GetHashCode()) % colors.Length];
    }

    string TimeAgo(DateTime dt)
    {
        var span = DateTime.UtcNow - dt.ToUniversalTime();
        if (span.TotalMinutes < 1)  return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours   < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays    < 7)  return $"{(int)span.TotalDays}d ago";
        return dt.ToString("MMM d, yyyy");
    }
}

<style>
@@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600;1,700&family=DM+Sans:wght@300;400;500;600;700&display=swap');

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

body, .container, main, .pb-5, .mt-4 {
    background: #f9f5ef !important;
}

.forum-shell {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1.5rem 6rem;
    background: #f9f5ef;
}

/* ══════════════════════════
   MASTHEAD
══════════════════════════ */
.f-masthead {
    background: linear-gradient(135deg, #2a1f14 0%, #3d2b1a 60%, #4a3520 100%);
    border-radius: 20px;
    padding: 2.5rem 3rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(42,31,20,0.25), 0 1px 4px rgba(42,31,20,0.15);
}

.f-masthead::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 280px; height: 280px;
    background: radial-gradient(circle, rgba(200,82,26,0.25) 0%, transparent 70%);
    pointer-events: none;
}

.f-masthead::after {
    content: '';
    position: absolute;
    bottom: -40px; left: 30%;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(255,255,255,0.04) 0%, transparent 70%);
    pointer-events: none;
}

.f-masthead-watermark {
    position: absolute;
    right: 2.5rem; top: 50%;
    transform: translateY(-50%);
    font-family: 'Cormorant Garamond', serif;
    font-size: 9rem;
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,0.07);
    line-height: 1;
    letter-spacing: -0.02em;
    pointer-events: none;
    user-select: none;
}

.f-masthead-left { position: relative; z-index: 1; }

.f-masthead-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #e8a87c;
    margin-bottom: 0.65rem;
}

.f-masthead-eyebrow::before {
    content: '';
    display: block;
    width: 24px; height: 1px;
    background: #e8a87c;
}

.f-masthead-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #fdf6ee;
    line-height: 0.92;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
}

.f-masthead-title em {
    font-style: italic;
    color: #e8754a;
}

.f-masthead-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
}

.f-masthead-stat-value {
    font-size: 1.4rem;
    font-weight: 800;
    color: #fdf6ee;
    line-height: 1;
    display: block;
}

.f-masthead-stat-label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(253,246,238,0.45);
    display: block;
    margin-top: 0.15rem;
}

.f-masthead-stat-divider {
    width: 1px;
    height: 30px;
    background: rgba(255,255,255,0.12);
}

.f-btn-new-post {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1.9rem;
    background: #e85d26;
    color: white;
    border: none;
    border-radius: 100px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 4px 20px rgba(232,93,38,0.45), inset 0 1px 0 rgba(255,255,255,0.15);
    white-space: nowrap;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
}

.f-btn-new-post:hover {
    background: #d14f1e;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(232,93,38,0.55);
    color: white;
    text-decoration: none;
}

.f-btn-new-post svg {
    width: 15px; height: 15px;
    stroke: currentColor; fill: none;
    stroke-width: 2.5; stroke-linecap: round;
}

/* ══════════════════════════
   LAYOUT
══════════════════════════ */
.f-layout {
    display: grid;
    grid-template-columns: 205px 1fr;
    gap: 1.5rem;
    align-items: start;
}

/* ══════════════════════════
   SIDEBAR
══════════════════════════ */
.f-sidebar { position: sticky; top: 1.5rem; }

.f-sidebar-section {
    background: #fdf8f2;
    border-radius: 14px;
    border: 1px solid rgba(180,145,100,0.2);
    overflow: hidden;
    margin-bottom: 0.85rem;
    box-shadow: 0 1px 3px rgba(100,70,30,0.06);
}

.f-sidebar-head {
    padding: 0.8rem 1rem;
    background: #f5ede0;
    border-bottom: 1px solid rgba(180,145,100,0.18);
    display: flex;
    align-items: center;
    gap: 0.55rem;
}

.f-sidebar-head-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #e85d26;
    flex-shrink: 0;
}

.f-sidebar-head-title {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #7a6550;
}

.f-sidebar-body { padding: 0.4rem; }

.f-sort-tab {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.58rem 0.7rem;
    border-radius: 9px;
    font-size: 0.82rem;
    font-weight: 500;
    color: #6b5740;
    text-decoration: none;
    transition: all 0.15s;
    margin-bottom: 0.08rem;
    position: relative;
}

.f-sort-tab:hover {
    background: #f0e6d6;
    color: #2a1f14;
    text-decoration: none;
}

.f-sort-tab.active {
    background: rgba(232,93,38,0.1);
    color: #c8521a;
    font-weight: 700;
}

.f-sort-tab.active::before {
    content: '';
    position: absolute;
    left: 0; top: 25%; bottom: 25%;
    width: 3px;
    background: #e85d26;
    border-radius: 0 3px 3px 0;
}

.f-flair-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.52rem 0.7rem;
    border-radius: 9px;
    font-size: 0.79rem;
    font-weight: 500;
    color: #6b5740;
    text-decoration: none;
    transition: all 0.15s;
    margin-bottom: 0.05rem;
}

.f-flair-item:hover {
    background: #f0e6d6;
    color: #2a1f14;
    text-decoration: none;
}

.f-flair-item.active {
    background: #ede3d4;
    color: #2a1f14;
    font-weight: 700;
}

.f-flair-pip {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
}

/* ══════════════════════════
   FEED
══════════════════════════ */
.f-feed-bar {
    display: flex;
    align-items: center;
    margin-bottom: 1rem;
    padding: 0 0.25rem;
}

.f-feed-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #a8927a;
}

.f-feed-label strong { color: #6b5740; }

.f-post-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

/* ══════════════════════════
   POST CARD
══════════════════════════ */
.f-post-card {
    background: #fdf8f2;
    border-radius: 16px;
    border: 1px solid rgba(180,145,100,0.2);
    box-shadow: 0 1px 3px rgba(100,70,30,0.06), 0 3px 12px rgba(100,70,30,0.05);
    overflow: hidden;
    display: grid;
    grid-template-columns: 60px 1fr;
    transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease, background 0.2s;
    cursor: pointer;
    animation: f-card-in 0.45s cubic-bezier(0.22,1,0.36,1) both;
}

.f-post-card:hover {
    background: #fffdf9;
    box-shadow: 0 2px 6px rgba(100,70,30,0.08), 0 12px 36px rgba(100,70,30,0.12);
    transform: translateY(-4px);
    border-color: rgba(180,145,100,0.38);
}

@@keyframes f-card-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
}

.f-post-card:nth-child(1) { animation-delay: 0.04s; }
.f-post-card:nth-child(2) { animation-delay: 0.09s; }
.f-post-card:nth-child(3) { animation-delay: 0.14s; }
.f-post-card:nth-child(4) { animation-delay: 0.19s; }
.f-post-card:nth-child(5) { animation-delay: 0.24s; }
.f-post-card:nth-child(6) { animation-delay: 0.29s; }
.f-post-card:nth-child(7) { animation-delay: 0.34s; }
.f-post-card:nth-child(8) { animation-delay: 0.39s; }

/* ── Vote column ── */
.f-vote-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 1.5rem 0;
    background: #f5ede0;
    border-right: 1px solid rgba(180,145,100,0.18);
    transition: background 0.2s;
}

.f-post-card:hover .f-vote-col {
    background: #eee4d4;
}

.f-vote-btn {
    width: 34px; height: 34px;
    border: none;
    background: none;
    display: flex; align-items: center; justify-content: center;
    border-radius: 8px;
    cursor: pointer;
    color: #c4b09a;
    transition: all 0.15s;
    flex-shrink: 0;
}

.f-vote-btn:hover {
    background: rgba(232,93,38,0.12);
    color: #e85d26;
}

.f-vote-btn.up.voted { color: #e85d26; }
.f-vote-btn.down.voted { color: #6b7280; }

.f-vote-btn svg {
    width: 15px; height: 15px;
    stroke: currentColor; fill: none;
    stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
    transition: transform 0.15s;
}

.f-vote-btn.up:hover svg  { transform: translateY(-2px); }
.f-vote-btn.down:hover svg { transform: translateY(2px); }

.f-vote-score-wrap {
    padding: 0.3rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
}

.f-vote-score {
    font-size: 1rem;
    font-weight: 800;
    color: #6b5740;
    line-height: 1;
    text-align: center;
    min-width: 30px;
    font-variant-numeric: tabular-nums;
    transition: color 0.15s;
}

.f-vote-score.pos { color: #c8521a; }
.f-vote-score.neg { color: #6b7280; }

.f-vote-label {
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c4b09a;
}

/* ── Post content ── */
.f-post-body {
    padding: 1.35rem 1.5rem 1.2rem;
    min-width: 0;
    display: flex;
    flex-direction: column;
}

.f-post-author-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
}

.f-author-avatar {
    width: 26px; height: 26px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.62rem;
    font-weight: 800;
    color: white;
    flex-shrink: 0;
    box-shadow: 0 1px 4px rgba(0,0,0,0.18);
}

.f-author-name {
    font-size: 0.8rem;
    font-weight: 700;
    color: #2a1f14;
}

.f-author-sep {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: #c4b09a;
    flex-shrink: 0;
}

.f-post-time {
    font-size: 0.72rem;
    color: #a8927a;
    font-weight: 400;
}

.f-post-flair {
    display: inline-flex;
    align-items: center;
    padding: 0.14rem 0.55rem;
    border-radius: 100px;
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
}

/* Title */
.f-post-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.45rem;
    font-weight: 700;
    color: #1a1208;
    line-height: 1.2;
    margin-bottom: 0.55rem;
    text-decoration: none;
    display: block;
    letter-spacing: -0.02em;
    transition: color 0.15s;
}

.f-post-card:hover .f-post-title { color: #c8521a; }

/* Preview */
.f-post-preview {
    font-size: 0.875rem;
    color: #6b5740;
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 400;
    min-height: 2.9rem;
    flex-grow: 1;
}

/* Recipe tag */
.f-recipe-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: #c8521a;
    font-weight: 600;
    text-decoration: none;
    margin-top: 0.65rem;
    padding: 0.28rem 0.7rem;
    background: rgba(200,82,26,0.08);
    border-radius: 100px;
    border: 1px solid rgba(200,82,26,0.15);
    transition: background 0.15s;
    width: fit-content;
}

.f-recipe-tag:hover { background: rgba(200,82,26,0.14); text-decoration: none; color: #c8521a; }

/* Footer */
.f-post-footer {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    margin-top: 1rem;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(180,145,100,0.16);
}

.f-post-action {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    padding: 0.3rem 0.62rem;
    border-radius: 7px;
    font-size: 0.73rem;
    font-weight: 600;
    color: #a8927a;
    text-decoration: none;
    transition: all 0.15s;
    border: none;
    background: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
}

.f-post-action:hover {
    background: rgba(200,82,26,0.08);
    color: #c8521a;
    text-decoration: none;
}

.f-post-action svg {
    width: 13px; height: 13px;
    stroke: currentColor; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
}

.f-action-sep {
    width: 1px; height: 14px;
    background: rgba(180,145,100,0.25);
    margin: 0 0.1rem;
    flex-shrink: 0;
}

/* ══════════════════════════
   EMPTY STATE
══════════════════════════ */
.f-empty {
    background: #fdf8f2;
    border-radius: 16px;
    border: 1px solid rgba(180,145,100,0.2);
    padding: 5rem 2rem;
    text-align: center;
}

.f-empty-icon { font-size: 3.5rem; display: block; margin-bottom: 1rem; opacity: 0.4; }

.f-empty-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 600;
    color: #a8927a;
    margin-bottom: 0.5rem;
}

.f-beta-banner{
    display:flex;
    align-items:flex-start;
    gap:0.9rem;
    padding:1rem 1.1rem;
    margin:0 0 1.25rem 0;
    background:linear-gradient(135deg,#fff6e8,#fffaf2);
    border:1px solid rgba(232,93,38,0.22);
    border-radius:14px;
    box-shadow:0 2px 6px rgba(100,70,30,0.05);
}

.f-beta-icon{
    width:34px;
    height:34px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    background:#e85d26;
    color:#fff;
    font-size:1rem;
    font-weight:700;
    flex-shrink:0;
}

.f-beta-content{
    flex:1;
}

.f-beta-title{
    font-size:0.78rem;
    font-weight:800;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:#c8521a;
    margin-bottom:0.2rem;
}

.f-beta-text{
    font-size:0.88rem;
    line-height:1.55;
    color:#6b5740;
}

@@media (max-width:560px){
    .f-beta-banner{
        padding:0.9rem;
        gap:0.7rem;
    }

    .f-beta-icon{
        width:30px;
        height:30px;
        font-size:0.9rem;
    }

    .f-beta-text{
        font-size:0.82rem;
    }
}

.f-empty-sub { font-size: 0.88rem; color: #c4b09a; }

.f-btn-empty {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    padding: 0.72rem 1.5rem;
    background: #e85d26;
    color: white;
    border-radius: 100px;
    font-size: 0.83rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
}

.f-btn-empty:hover { background: #d14f1e; transform: translateY(-1px); color: white; text-decoration: none; }

/* ══════════════════════════
   PAGINATION
══════════════════════════ */
.f-pagination {
    margin-top: 2.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
}

.f-page-link {
    display: flex; align-items: center; justify-content: center;
    min-width: 40px; height: 40px; padding: 0 0.75rem;
    border: 1px solid rgba(180,145,100,0.3);
    background: #fdf8f2;
    color: #6b5740;
    text-decoration: none;
    border-radius: 9px;
    font-size: 0.83rem;
    font-weight: 600;
    transition: all 0.15s;
}

.f-page-link:hover { border-color: #e85d26; color: #e85d26; background: rgba(232,93,38,0.06); text-decoration: none; }
.f-page-link.active { background: #2a1f14; border-color: #2a1f14; color: white; }
.f-page-link.prev-next { font-size: 0.72rem; letter-spacing: 0.05em; text-transform: uppercase; padding: 0 1rem; }
.f-page-ellipsis { display: flex; align-items: center; color: #c4b09a; padding: 0 0.25rem; }

/* ══════════════════════════
   RESPONSIVE
══════════════════════════ */
@@media (max-width: 860px) {
    .f-layout { grid-template-columns: 1fr; }
    .f-sidebar { position: relative; top: 0; }
    .f-masthead { padding: 1.75rem; }
    .f-masthead-watermark { display: none; }
}

@@media (max-width: 560px) {
    .forum-shell { padding: 1rem 0.75rem 4rem; }
    .f-post-card { grid-template-columns: 50px 1fr; }
    .f-post-body { padding: 1rem; }
    .f-post-title { font-size: 1.2rem; }
    .f-masthead-stats { display: none; }
}
</style>

<div class="forum-shell">

    <!-- ══ MASTHEAD ══ -->
    <div class="f-masthead">
        <div class="f-masthead-left">
            <div class="f-masthead-eyebrow">Community Kitchen</div>
            <div class="f-masthead-title">Share &amp; <em>Discuss</em></div>
            <div class="f-masthead-stats">
                <div class="f-masthead-stat">
                    <span class="f-masthead-stat-value">@Model.TotalCount</span>
                    <span class="f-masthead-stat-label">Posts</span>
                </div>
                <div class="f-masthead-stat-divider"></div>
                <div class="f-masthead-stat">
                    <span class="f-masthead-stat-value">@Model.Flairs.Count()</span>
                    <span class="f-masthead-stat-label">Topics</span>
                </div>
            </div>
        </div>
        <div class="f-masthead-watermark" aria-hidden="true">FORUM</div>
        <a asp-action="Create" class="f-btn-new-post">
            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            New Post
        </a>
    </div>
    
    <div class="f-beta-banner">
        <div class="f-beta-icon">⚠</div>

        <div class="f-beta-content">
            <div class="f-beta-title">Forum Beta</div>

            <div class="f-beta-text">
                The community forum is currently in beta. All new posts and comments require admin approval before appearing publicly while moderation tools are being improved. Thanks for your patience as we grow.
            </div>
        </div>
    </div>


    <div class="f-layout">

        <!-- ══ SIDEBAR ══ -->
        <aside class="f-sidebar">

            <div class="f-sidebar-section">
                <div class="f-sidebar-head">
                    <span class="f-sidebar-head-dot"></span>
                    <span class="f-sidebar-head-title">Sort By</span>
                </div>
                <div class="f-sidebar-body">
                    <a class="f-sort-tab @(Model.Sort == "hot" ? "active" : "")"
                       asp-action="Index" asp-route-sort="hot" asp-route-flairId="@Model.FilterFlairId">
                        🔥 Hot
                    </a>
                    <a class="f-sort-tab @(Model.Sort == "new" ? "active" : "")"
                       asp-action="Index" asp-route-sort="new" asp-route-flairId="@Model.FilterFlairId">
                        ✨ New
                    </a>
                    <a class="f-sort-tab @(Model.Sort == "top" ? "active" : "")"
                       asp-action="Index" asp-route-sort="top" asp-route-flairId="@Model.FilterFlairId">
                        📈 Top All Time
                    </a>
                </div>
            </div>

            @if (Model.Flairs.Any())
            {
                <div class="f-sidebar-section">
                    <div class="f-sidebar-head">
                        <span class="f-sidebar-head-dot" style="background:#2d6a4f"></span>
                        <span class="f-sidebar-head-title">Browse Topics</span>
                    </div>
                    <div class="f-sidebar-body">
                        <a class="f-flair-item @(Model.FilterFlairId == null ? "active" : "")"
                           asp-action="Index" asp-route-sort="@Model.Sort">
                            <span class="f-flair-pip" style="background:#a8927a"></span>
                            All Posts
                        </a>
                        @foreach (var flair in Model.Flairs)
                        {
                            <a class="f-flair-item @(Model.FilterFlairId == flair.Id ? "active" : "")"
                               asp-action="Index" asp-route-sort="@Model.Sort" asp-route-flairId="@flair.Id">
                                <span class="f-flair-pip" style="background:@flair.ColorHex"></span>
                                @flair.Name
                            </a>
                        }
                    </div>
                </div>
            }

        </aside>

        <!-- ══ FEED ══ -->
        <main>
            <div class="f-feed-bar">
                <div class="f-feed-label">
                    Showing <strong>@Model.Posts.Count()</strong> of <strong>@Model.TotalCount</strong> posts
                </div>
            </div>

            @if (!Model.Posts.Any())
            {
                <div class="f-empty">
                    <span class="f-empty-icon">🍽</span>
                    <div class="f-empty-title">Nothing here yet</div>
                    <div class="f-empty-sub">Be the first to start a discussion!</div>
                    <a asp-action="Create" class="f-btn-empty">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Start the conversation
                    </a>
                </div>
            }
            else
            {
                <div class="f-post-list">
                    @foreach (var post in Model.Posts)
                    {
                        string upClass    = post.UserVote == 1  ? "voted" : "";
                        string downClass  = post.UserVote == -1 ? "voted" : "";
                        string scoreClass = post.VoteScore > 0  ? "pos"   : post.VoteScore < 0 ? "neg" : "";

                        var avatarColors = new[] { "#c0513d","#2d6a4f","#b5550a","#1d4ed8","#6d28d9","#be185d","#0e7490" };
                        string avatarBg  = avatarColors[Math.Abs(post.AuthorName.GetHashCode()) % avatarColors.Length];

                        <article class="f-post-card" id="post-@post.Id"
                                 onclick="window.location='@Url.Action("Details","Forum", new { id = post.Id })'">

                            <!-- Vote -->
                            <div class="f-vote-col">
                                <button class="f-vote-btn up @upClass"
                                        onclick="event.stopPropagation(); votePost(@post.Id, 1)"
                                        title="Upvote">
                                    <svg viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"/></svg>
                                </button>
                                <div class="f-vote-score-wrap">
                                    <span class="f-vote-score @scoreClass" id="score-@post.Id">@post.VoteScore</span>
                                    <span class="f-vote-label">votes</span>
                                </div>
                                <button class="f-vote-btn down @downClass"
                                        onclick="event.stopPropagation(); votePost(@post.Id, -1)"
                                        title="Downvote">
                                    <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                            </div>

                            <!-- Content -->
                            <div class="f-post-body">
                                <div class="f-post-author-row">
                                    <div class="f-author-avatar" style="background:@avatarBg">
                                        @(post.AuthorName.Length > 0 ? post.AuthorName[0].ToString().ToUpper() : "?")
                                    </div>
                                    <span class="f-author-name">@post.AuthorName</span>
                                    <span class="f-author-sep"></span>
                                    <span class="f-post-time">@TimeAgo(post.CreatedAt)</span>
                                    @if (!string.IsNullOrEmpty(post.FlairName))
                                    {
                                        <span class="f-post-flair"
                                              style="background:@(post.FlairColorHex + "22");color:@post.FlairColorHex">
                                            @post.FlairName
                                        </span>
                                    }
                                </div>

                                <a class="f-post-title"
                                   asp-action="Details" asp-route-id="@post.Id"
                                   onclick="event.stopPropagation()">@post.Title</a>

                                <p class="f-post-preview">@post.BodyPreview</p>

                                @if (post.RecipeId.HasValue)
                                {
                                    <a class="f-recipe-tag"
                                       asp-controller="Recipe" asp-action="Details"
                                       asp-route-id="@post.RecipeId"
                                       onclick="event.stopPropagation()">
                                        🍴 @post.RecipeName
                                    </a>
                                }

                                <div class="f-post-footer">
                                    <a class="f-post-action"
                                       asp-action="Details" asp-route-id="@post.Id"
                                       asp-fragment="comments"
                                       onclick="event.stopPropagation()">
                                        <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                        @post.CommentCount @(post.CommentCount == 1 ? "comment" : "comments")
                                    </a>
                                    <span class="f-action-sep"></span>
                                    <a class="f-post-action"
                                       asp-action="Details" asp-route-id="@post.Id"
                                       onclick="event.stopPropagation()">
                                        <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                        Read post
                                    </a>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }

            @if (Model.TotalPages > 1)
            {
                string PageUrl(int pg) => $"?sort={Model.Sort}&page={pg}&flairId={Model.FilterFlairId}";
                <nav class="f-pagination" aria-label="Pagination">
                    @if (Model.CurrentPage > 1)
                    {
                        <a class="f-page-link prev-next" href="@PageUrl(Model.CurrentPage - 1)">← Prev</a>
                    }
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 2 && i <= Model.CurrentPage + 2))
                        {
                            <a class="f-page-link @(i == Model.CurrentPage ? "active" : "")" href="@PageUrl(i)">@i</a>
                        }
                        else if (i == Model.CurrentPage - 3 || i == Model.CurrentPage + 3)
                        {
                            <span class="f-page-ellipsis">···</span>
                        }
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a class="f-page-link prev-next" href="@PageUrl(Model.CurrentPage + 1)">Next →</a>
                    }
                </nav>
            }
        </main>
    </div>
</div>

<script>
async function votePost(postId, value) {
    try {
        const res = await fetch('/Forum/Vote', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `postId=${postId}&value=${value}&__RequestVerificationToken=${getToken()}`
        });
        const data = await res.json();
        if (!data.success) return;

        const scoreEl = document.getElementById(`score-${postId}`);
        const card    = document.getElementById(`post-${postId}`);

        if (scoreEl) {
            scoreEl.textContent = data.newScore;
            scoreEl.className = 'f-vote-score' + (data.newScore > 0 ? ' pos' : data.newScore < 0 ? ' neg' : '');
        }
        if (card) {
            card.querySelectorAll('.f-vote-btn').forEach(b => b.classList.remove('voted'));
            if (data.userVote ===  1) card.querySelector('.f-vote-btn.up')?.classList.add('voted');
            if (data.userVote === -1) card.querySelector('.f-vote-btn.down')?.classList.add('voted');
        }
    } catch(e) { console.error(e); }
}

function getToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
}
</script>

<form style="display:none">@Html.AntiForgeryToken()</form>